{
  "name": "nightwatch-agent",
  "version": "1.0.0",
  "description": "Autonomous SRE agent that monitors Docker containers and remediates incidents",
  "type": "module",
  "bin": {
    "nightwatch": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && copyfiles \"src/**/*.md\" \"src/**/*.json\" dist -u 1",
    "dev": "tsx src/index.ts",
    "dev:clipper": "tsx src/index.ts --compose clipper/docker-compose.yaml"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "dockerode": "^4.0.2",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.47",
    "copyfiles": "^2.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
